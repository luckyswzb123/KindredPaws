# ==========================================
# 萌爪家园 (Kindred Paws) 环境变量配置
# 复制此文件为 .env 并填入实际值
# ==========================================

# Gemini AI API Key（AI Studio 自动注入）
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP URL（Cloud Run 自动注入）
APP_URL="YOUR_APP_URL"

# ==========================================
# Supabase 配置（在线云数据库）
# 获取方式: https://supabase.com → 项目 Settings → API
# ==========================================

# 项目 URL（格式: https://xxxxxxxxxxxx.supabase.co）
SUPABASE_URL="https://xxxxx.supabase.co"

# Anon Public Key（前端可用，受 RLS 保护）
SUPABASE_ANON_KEY="your_anon_key_here"

# Service Role Key（仅后端使用，拥有完整权限，不可暴露给前端）
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key_here"

# ==========================================
# 后端服务配置
# ==========================================

# 后端监听端口（默认 3001）
PORT=3001

# 允许跨域的前端地址
FRONTEND_URL=http://localhost:3000

# ==========================================
# Cloudflare R2 配置 (对象存储)
# 用于后台上传宠物图片
# ==========================================
R2_S3_API_URL="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="your-access-key-id"
R2_SECRET_ACCESS_KEY="your-secret-access-key"
R2_BUCKET_NAME="kindred-paws-assets"
R2_PUBLIC_DOMAIN="https://pub-your-id.r2.dev"
